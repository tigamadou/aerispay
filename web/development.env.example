# Copier vers `.env` à la racine du dépôt pour **docker compose** :
#   cp web/development.env.example .env
#   docker compose up -d
#
# **APP_BIND** (montage du service `app`) : le compose racine monte par défaut
# `./web/app` dans `/app`. Définir APP_BIND uniquement si le projet Next.js est déplacé.
#
# Pour l’app **dans Docker** (service `app`), `DATABASE_URL` est surchargée dans
# docker-compose (hôte `db`). Sur l’hôte (sans le service `app`) : `web/app/.env.local` avec
# DATABASE_URL=...@localhost:3306

# MySQL (service `db` — docker-compose.yml)
MYSQL_ROOT_PASSWORD=rootsecret
MYSQL_DATABASE=aerispay
MYSQL_USER=aerispay
MYSQL_PASSWORD=aerispay
MYSQL_PORT=3306

# phpMyAdmin
PHPMYADMIN_PORT=8080

# Application (service `app` — optionnel, défauts dans le compose)
APP_PORT=3000
# Décommenter uniquement si le projet Next.js n'est plus dans `web/app`.
#APP_BIND=./web/app

# NextAuth (requis pour l’app : conteneur ou hôte)
# URL publique telle que vue par le navigateur (ex. http://localhost:3000)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="changez-moi-en-dev"

# Développement sur l’hôte uniquement (pas le service `app` Docker) :
# Prisma (MySQL) : mysql://USER:PASSWORD@HOST:PORT/DATABASE
# DATABASE_URL="mysql://aerispay:aerispay@localhost:3306/aerispay"

# Contexte point de vente (optionnel, multi-magasins — voir SPECS/MULTI_ORGANISATION.md)
# Un déploiement = souvent un magasin ; le code / tickets peuvent afficher ce code.
#POINT_DE_VENTE_ID=
#POINT_DE_VENTE_CODE=PDV-01
#STRUCTURE_NOM=Mon groupe

# Périphériques caisse (optionnels)
PRINTER_ENABLED=false
PRINTER_TYPE=EPSON
PRINTER_INTERFACE=tcp://192.168.1.100:9100
PRINTER_WIDTH=48
PRINTER_AUTO_PRINT=false
CASH_DRAWER_ENABLED=false
CASH_DRAWER_MODE=printer
CASH_DRAWER_PIN=2
CASH_DRAWER_OPEN_ON_CASH=true
