# Copier vers la racine en `.env` si vous utilisez `docker compose` avec interpolation,
# ou fusionner dans `.env.local` pour Next.js (priorité pour l'app sur l'hôte).

# MySQL (service `db` — docker-compose.yml)
MYSQL_ROOT_PASSWORD=rootsecret
MYSQL_DATABASE=aerispay
MYSQL_USER=aerispay
MYSQL_PASSWORD=aerispay
MYSQL_PORT=3306

# phpMyAdmin
PHPMYADMIN_PORT=8080

# URL Prisma / NextAuth côté hôte (app lancée avec `npm run dev`)
# Prisma (MySQL) : mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://aerispay:aerispay@localhost:3306/aerispay"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="changez-moi-en-dev"
