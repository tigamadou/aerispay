# Fichier d'exemple pour la production.
# Copier vers un fichier NON versionné à la racine (ex. `.env.production`) et remplir les secrets.
#
# Démarrage :
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build
#
# Le service `app` résout le hostname `db` sur le réseau Compose : utiliser `db` comme hôte MySQL.

MYSQL_ROOT_PASSWORD=remplacer-root-fort
MYSQL_DATABASE=aerispay
MYSQL_USER=aerispay
MYSQL_PASSWORD=remplacer-mdp-fort

# Aligné sur MYSQL_USER / MYSQL_PASSWORD / MYSQL_DATABASE (hôte = service `db`, port 3306)
DATABASE_URL="mysql://aerispay:remplacer-mdp-fort@db:3306/aerispay"

# URL publique de l'application (HTTPS en prod)
NEXTAUTH_URL="https://aerispay.exemple.com"

# openssl rand -base64 32
NEXTAUTH_SECRET=remplacer-secret-32-octets-min

# Port exposé sur l'hôte pour l'app
PORT=3000

# Tag de l'image (optionnel)
# AERISPAY_TAG=1.0.0

# Contexte point de vente (optionnel, multi-magasins — voir SPECS/MULTI_ORGANISATION.md)
#POINT_DE_VENTE_ID=
#POINT_DE_VENTE_CODE=PDV-01
#STRUCTURE_NOM=Mon groupe

# Périphériques caisse
PRINTER_ENABLED=false
PRINTER_TYPE=EPSON
PRINTER_INTERFACE=tcp://192.168.1.100:9100
PRINTER_WIDTH=48
PRINTER_AUTO_PRINT=true
CASH_DRAWER_ENABLED=false
CASH_DRAWER_MODE=printer
CASH_DRAWER_PIN=2
CASH_DRAWER_OPEN_ON_CASH=true
