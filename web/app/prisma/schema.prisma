// Aligné sur ARCHITECTURE_MVP.md — champs en français
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "mysql"
  url               = env("DATABASE_URL")
  // `prisma migrate dev` : utilisateur avec droit CREATE DATABASE (souvent `root` en local).
  // L’utilisateur app (`aerispay`) n’a en général pas ce droit → P3014 sans shadow.
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

// ─── UTILISATEURS & AUTH ────────────────────────────

model User {
  id         String   @id @default(cuid())
  nom        String
  email      String   @unique
  motDePasse String
  role       Role     @default(CAISSIER)
  actif      Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sessions               ComptoirSession[]
  sessionsValidees       ComptoirSession[] @relation("SessionValideur")
  ventes                 Vente[]
  mouvementsCaisseAuteur MouvementCaisse[] @relation("MouvementCaisseAuteur")
  activityLogs           ActivityLog[]

  @@map("users")
}

enum Role {
  ADMIN
  MANAGER
  CAISSIER
}

// ─── MODULE STOCK ───────────────────────────────────

model Categorie {
  id          String   @id @default(cuid())
  nom         String
  description String?
  couleur     String?
  createdAt   DateTime @default(now())

  produits Produit[]

  @@map("categories")
}

model Produit {
  id           String   @id @default(cuid())
  reference    String   @unique
  codeBarres   String?  @unique
  nom          String
  description  String?
  image        String?
  prixAchat    Decimal  @db.Decimal(10, 2)
  prixVente    Decimal  @db.Decimal(10, 2)
  tva          Decimal  @default(0) @db.Decimal(5, 2)
  unite        String   @default("unité")
  stockActuel  Int      @default(0)
  stockMinimum Int      @default(5)
  stockMaximum Int?
  actif        Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  categorieId String
  categorie   Categorie        @relation(fields: [categorieId], references: [id])
  mouvements  MouvementStock[]
  lignesVente LigneVente[]

  @@map("produits")
}

model MouvementStock {
  id            String        @id @default(cuid())
  type          TypeMouvement
  quantite      Int
  quantiteAvant Int
  quantiteApres Int
  motif         String?
  reference     String?
  createdAt     DateTime      @default(now())

  produitId String
  produit   Produit @relation(fields: [produitId], references: [id])
  venteId   String?
  vente     Vente?  @relation(fields: [venteId], references: [id])

  @@map("mouvements_stock")
}

enum TypeMouvement {
  ENTREE
  SORTIE
  AJUSTEMENT
  RETOUR
  PERTE
}

// ─── MODULE CAISSE ────────────────────────────────────

model Caisse {
  id        String   @id @default(cuid())
  nom       String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  mouvements MouvementCaisse[]

  @@map("caisses")
}

// ─── MODULE COMPTOIR / SESSIONS ──────────────────────

model ComptoirSession {
  id          String    @id @default(cuid())
  ouvertureAt DateTime  @default(now())
  fermetureAt DateTime?

  // Montants declares a l'ouverture (snapshot de ce que le caissier compte)
  montantOuvertureCash        Decimal @db.Decimal(10, 2)
  montantOuvertureMobileMoney Decimal @default(0) @db.Decimal(10, 2)

  // Déclarations caissier (étape 1 de clôture) — JSON { mode: montant }
  declarationsCaissier Json?
  demandeCloturAt      DateTime?

  // Déclarations valideur (étape 3 — validation à l'aveugle) — JSON { mode: montant }
  declarationsValideur Json?

  // Résultats fermeture (conservés pour rétrocompatibilité MVP)
  montantFermetureCash        Decimal? @db.Decimal(10, 2)
  montantFermetureMobileMoney Decimal? @db.Decimal(10, 2)
  soldeTheoriqueCash          Decimal? @db.Decimal(10, 2)
  soldeTheoriqueMobileMoney   Decimal? @db.Decimal(10, 2)
  ecartCash                   Decimal? @db.Decimal(10, 2)
  ecartMobileMoney            Decimal? @db.Decimal(10, 2)

  // Écarts finaux par mode — JSON { mode: { theorique, declare, ecart, categorie } }
  ecartsParMode Json?

  // Intégrité
  hashIntegrite         String? @db.VarChar(64)
  hashSessionPrecedente String? @db.VarChar(64)

  // Recomptage / contestation
  tentativesRecomptage Int @default(0)

  // Force-close
  motifForceClose String? @db.Text

  statut StatutSession @default(OUVERTE)
  notes  String?

  // Relations
  userId     String
  user       User    @relation(fields: [userId], references: [id])
  valideurId String?
  valideur   User?   @relation("SessionValideur", fields: [valideurId], references: [id])

  ventes           Vente[]
  mouvementsCaisse MouvementCaisse[]

  // Session corrective : cette session corrige une session originale
  sessionCorrigeeId String?          @unique
  sessionCorrigee   ComptoirSession? @relation("SessionCorrective", fields: [sessionCorrigeeId], references: [id])
  sessionCorrective ComptoirSession? @relation("SessionCorrective")

  @@map("comptoir_sessions")
}

enum StatutSession {
  OUVERTE
  FERMEE // conservé pour rétrocompatibilité données existantes
  EN_ATTENTE_CLOTURE
  EN_ATTENTE_VALIDATION
  VALIDEE
  CONTESTEE
  FORCEE
  CORRIGEE
}

// ─── MODULE CAISSE — MOUVEMENTS ─────────────────────

model MouvementCaisse {
  id           String              @id @default(cuid())
  type         TypeMouvementCaisse
  mode         String
  montant      Decimal             @db.Decimal(10, 2)
  motif        String?
  reference    String?
  justificatif String?             @db.Text
  offline      Boolean             @default(false)
  createdAt    DateTime            @default(now())

  caisseId  String
  caisse    Caisse          @relation(fields: [caisseId], references: [id])
  sessionId String?
  session   ComptoirSession? @relation(fields: [sessionId], references: [id])
  venteId   String?
  vente     Vente?           @relation(fields: [venteId], references: [id])
  auteurId  String
  auteur    User             @relation("MouvementCaisseAuteur", fields: [auteurId], references: [id])

  @@index([caisseId])
  @@index([sessionId])
  @@index([venteId])
  @@index([auteurId])
  @@index([createdAt])
  @@map("mouvements_caisse")
}

enum TypeMouvementCaisse {
  FOND_INITIAL
  VENTE
  REMBOURSEMENT
  APPORT
  RETRAIT
  DEPENSE
  CORRECTION
}

// ─── MODULE CAISSE — SEUILS PARAMÉTRABLES ───────────

model SeuilCaisse {
  id          String   @id
  valeur      Int
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("seuils_caisse")
}

// ─── MODULE CAISSE — ÉVÉNEMENTS MÉTIER ──────────────

model EventCaisse {
  id          String   @id @default(cuid())
  type        String   // EVT-SESSION-OPENED, EVT-CASH-MOVEMENT-CREATED, etc.
  sessionId   String?
  payload     Json
  consumed    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([type])
  @@index([sessionId])
  @@index([consumed, createdAt])
  @@map("events_caisse")
}

model Vente {
  id            String      @id @default(cuid())
  numero        String      @unique
  dateVente     DateTime    @default(now())
  sousTotal     Decimal     @db.Decimal(10, 2)
  remise        Decimal     @default(0) @db.Decimal(10, 2)
  tva           Decimal     @default(0) @db.Decimal(10, 2)
  taxesDetail   Json?
  total         Decimal     @db.Decimal(10, 2)
  statut        StatutVente @default(VALIDEE)
  nomClient     String?
  notesCaissier String?
  createdAt     DateTime    @default(now())

  sessionId        String
  session          ComptoirSession   @relation(fields: [sessionId], references: [id])
  userId           String
  caissier         User              @relation(fields: [userId], references: [id])
  lignes           LigneVente[]
  paiements        Paiement[]
  mouvementsStock  MouvementStock[]
  mouvementsCaisse MouvementCaisse[]

  @@map("ventes")
}

enum StatutVente {
  VALIDEE
  ANNULEE
  REMBOURSEE
}

model LigneVente {
  id           String  @id @default(cuid())
  quantite     Int
  prixUnitaire Decimal @db.Decimal(10, 2)
  remise       Decimal @default(0) @db.Decimal(10, 2)
  tva          Decimal @default(0) @db.Decimal(10, 2)
  sousTotal    Decimal @db.Decimal(10, 2)

  venteId   String
  vente     Vente   @relation(fields: [venteId], references: [id], onDelete: Cascade)
  produitId String
  produit   Produit @relation(fields: [produitId], references: [id])

  @@map("lignes_vente")
}

model Paiement {
  id        String  @id @default(cuid())
  mode      String
  montant   Decimal @db.Decimal(10, 2)
  reference String?
  createdAt DateTime     @default(now())

  venteId String
  vente   Vente  @relation(fields: [venteId], references: [id], onDelete: Cascade)

  @@map("paiements")
}

// ─── PARAMÈTRES STRUCTURE ────────────────────────────

model Parametres {
  id          String   @id @default("default")
  nomCommerce String   @default("")
  adresse     String   @default("")
  telephone   String   @default("")
  email       String   @default("")
  rccm        String   @default("")
  nif         String   @default("")
  logo        String?  @db.MediumText
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  taxes          Taxe[]
  modesPaiement  ModePaiementConfig[]

  @@map("parametres")
}

model ModePaiementConfig {
  id     String  @id @default(cuid())
  code   String  @unique
  label  String
  active Boolean @default(true)
  ordre  Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parametresId String     @default("default")
  parametres   Parametres @relation(fields: [parametresId], references: [id])

  @@map("modes_paiement")
}

model Taxe {
  id        String   @id @default(cuid())
  nom       String
  taux      Decimal  @db.Decimal(5, 2)
  active    Boolean  @default(true)
  ordre     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parametresId String     @default("default")
  parametres   Parametres @relation(fields: [parametresId], references: [id])

  @@map("taxes")
}

// ─── JOURNAL D'ACTIVITÉ ─────────────────────────────

model ActivityLog {
  id         String   @id @default(cuid())
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  ipAddress  String?  @db.VarChar(45)
  userAgent  String?  @db.Text
  createdAt  DateTime @default(now())

  actorId String?
  actor   User?   @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([actorId])
  @@index([action])
  @@index([entityType, entityId])
  @@map("activity_logs")
}
